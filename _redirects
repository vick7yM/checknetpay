# Cloudflare Pages URL Routing
# This file makes clean SEO URLs work without a backend server
# Format: /incoming-url  /actual-file  status-code
# 200 = serve the file silently (URL stays clean in browser) ← perfect for SEO

# ── STATE PAGES — served by _state.html ──
# _state.html uses underscore prefix so Cloudflare Pages does NOT create a conflicting
# pretty-URL route at /state — which was causing all state clicks to land on California.
/states/*  /_state.html  200

# ── LEGACY: redirect old /state pretty-URL to homepage ──
/state  /  301

# ── COMMON TYPOS / REDIRECTS ──
/calculator          /             301
/paycheck-calculator /             301
/take-home-pay       /             301
/takehome            /             301

# ── TRUST & POLICY PAGES — clean URLs without .html ──
/methodology        /methodology.html        200
/sources            /sources.html            200
/editorial-policy   /editorial-policy.html   200
/disclaimer         /disclaimer.html         200
/about              /about.html              200
/privacy            /privacy.html            200
/blog               /blog/index.html         200
