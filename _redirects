# Cloudflare Pages URL Routing
# This file makes clean SEO URLs work without a backend server
# Format: /incoming-url  /actual-file  status-code
# 200 = serve the file silently (URL stays clean in browser) ← perfect for SEO

# ── STATE PAGES — served by _state.html ──
# _state.html uses underscore prefix so Cloudflare Pages does NOT create a conflicting
# pretty-URL route at /state — which was causing all state clicks to land on California.
/states/*  /_state.html  200

# ── LEGACY: redirect old /state pretty-URL to homepage ──
/state  /  301

# ── COMMON TYPOS / REDIRECTS ──
/calculator          /             301
/paycheck-calculator /             301
/take-home-pay       /             301
/takehome            /             301

# ── TRUST & POLICY PAGES ──
# NOTE: Cloudflare Pages auto-generates pretty-URL routes for any top-level
# .html file (about.html -> /about, privacy.html -> /privacy, etc.) BEFORE
# this file is even read. Adding explicit rules for those same paths here
# creates a routing loop with Cloudflare's own auto-route (ERR_TOO_MANY_REDIRECTS).
# No rules needed below — /about, /privacy, /methodology, /sources,
# /editorial-policy, and /disclaimer already work automatically via
# Cloudflare's built-in pretty-URL behavior. Do not add explicit redirects
# for these paths.
